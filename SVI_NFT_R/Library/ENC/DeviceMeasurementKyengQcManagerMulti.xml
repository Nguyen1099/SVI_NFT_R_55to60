        <member name="M:DeviceDLL.Measurement.KYENG.QcManagerMulti.DeviceMeasurementKyengQcManagerMulti.TryReadOneChannel(System.Int32,System.Int32,System.Double@)">
            <inheritdoc/>
            <remarks>
            📌 매개변수 <paramref name="slaveIndex"/>의 입력 범위: 0 ~ 31<br/>
            📌 매개변수 <paramref name="channelIndex"/>의 입력 범위: 0 ~ 6
            </remarks>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new InitializeParameter()
            {
                Type = ECommType.Socket,
                SocketIPAddress = "127.0.0.1",
                SocketPortNumber = 502
            };
            
            // 라이브러리 초기화
            var device = new DeviceMeasurementKyengQcManagerMulti();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 단일 채널 읽기
            int slaveIndex = 0;
            int channelIndex = 0;
            double readValue;
            if (device.TryReadOneChannel(slaveIndex, channelIndex, out readValue) == true)
            {
                // 읽기에 성공한 경우
                Console.WriteLine($"읽은 값: {readValue:0.0000}");
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
            <b>예제 코드 콘솔 출력</b>
            <code>
            읽은 값: 0.1011
            </code>
        </member>
        <member name="M:DeviceDLL.Measurement.KYENG.QcManagerMulti.DeviceMeasurementKyengQcManagerMulti.TryReadAllChannels(System.Int32,System.Double[]@)">
            <inheritdoc/>
            <remarks>
            📌 매개변수 <paramref name="slaveIndex"/>의 입력 범위: 0 ~ 31
            </remarks>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new InitializeParameter()
            {
                Type = ECommType.Socket,
                SocketIPAddress = "127.0.0.1",
                SocketPortNumber = 502
            };
            
            // 라이브러리 초기화
            var device = new DeviceMeasurementKyengQcManagerMulti();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 모든 채널 읽기
            int slaveIndex = 0;
            double[] readValues;
            if (device.TryReadAllChannels(slaveIndex, out readValues) == true)
            {
                // 읽기에 성공한 경우
                Console.WriteLine($"읽은 값: {{ {string.Join(", ", readValues.Select(i => $"{i:0.0000}"))} }}");
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
            <b>예제 코드 콘솔 출력</b>
            <code>
            읽은 값: { 0.1011, 0.2011, 0.3011, 0.4011, 0.5011, 0.6011, 0.7011 }
            </code>
        </member>
        <member name="M:DeviceDLL.Measurement.KYENG.QcManagerMulti.DeviceMeasurementKyengQcManagerMulti.TryReadRandomChannels(System.Int32,System.Int32[],System.Double[]@)">
            <inheritdoc/>
            <remarks>
            📌 매개변수 <paramref name="slaveIndex"/>의 입력 범위: 0 ~ 31<br/>
            📌 매개변수 <paramref name="channelIndexes"/>의 개별 입력 범위: 0 ~ 6
            </remarks>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new InitializeParameter()
            {
                Type = ECommType.Socket,
                SocketIPAddress = "127.0.0.1",
                SocketPortNumber = 502
            };
            
            // 라이브러리 초기화
            var device = new DeviceMeasurementKyengQcManagerMulti();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 연속되지 않은 여러 채널 읽기
            int slaveIndex = 0;
            int[] channelIndexes = new int[] { 0, 2, 4, 6 };
            double[] readValues;
            if (device.TryReadRandomChannels(slaveIndex, channelIndexes, out readValues) == true)
            {
                // 읽기에 성공한 경우
                Console.WriteLine($"읽은 값: {{ {string.Join(", ", readValues.Select(i => $"{i:0.0000}"))} }}");
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
            <b>예제 코드 콘솔 출력</b>
            <code>
            읽은 값: { 0.1011, 0.3011, 0.5011, 0.7011 }
            </code>
        </member>
        <member name="M:DeviceDLL.Measurement.KYENG.QcManagerMulti.DeviceMeasurementKyengQcManagerMulti.TryReadSequncialChannels(System.Int32,System.Int32,System.Int32,System.Double[]@)">
            <inheritdoc/>
            <remarks>
            📌 매개변수 <paramref name="slaveIndex"/>의 입력 범위: 0 ~ 31<br/>
            📌 매개변수 <paramref name="startIndex"/>의 입력 범위: 0 ~ 6<br/>
            📌 매개변수 <paramref name="count"/>의 입력 범위: 1 ~ 7<br/>
            📌 매개변수 (<paramref name="startIndex"/> + <paramref name="count"/>) <![CDATA[<]]> 7
            </remarks>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new InitializeParameter()
            {
                Type = ECommType.Socket,
                SocketIPAddress = "127.0.0.1",
                SocketPortNumber = 502
            };
            
            // 라이브러리 초기화
            var device = new DeviceMeasurementKyengQcManagerMulti();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 연속된 여러 채널 읽기
            int slaveIndex = 0;
            int startIndex = 3;
            int count = 2;
            double[] readValues;
            if (device.TryReadSequncialChannels(slaveIndex, startIndex, count, out readValues) == true)
            {
                // 읽기에 성공한 경우
                Console.WriteLine($"읽은 값: {{ {string.Join(", ", readValues.Select(i => $"{i:0.0000}"))} }}");
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
            <b>예제 코드 콘솔 출력</b>
            <code>
            읽은 값: { 0.4011, 0.5011 }
            </code>
        </member>
