        <member name="M:HLDeviceDLL.Electrostatic.PGMS.CDeviceElectrostaticPGMS.HLInitialize(HLDeviceDLL.Electrostatic.PGMS.CDeviceElectrostaticPGMSDefine.CInitializeParameter)">
            <summary>
            라이브러리를 초기화하는 함수
            </summary>
            <remarks>
            <br>📌 입력된 초기화 파라미터로 라이브러리 내부에 코어를 초기화하고, 통신 자동 접속 스레드를 시작함</br>
            </remarks>
            <param name="objInitializeParameter">초기화 파라미터 객체</param>
            <returns>초기화 성공시 true를 실패시 false를 반환함</returns>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new CDeviceElectrostaticPGMSDefine.CInitializeParameter()
            {
                eType = CDeviceCommunicationAbstract.CInitializeParameter.enumType.TYPE_SERIAL,
                strSerialPortName = "COM1",
                iSerialPortBaudrate = 19200,
                iSerialPortDataBits = 8,
                eStopBits = CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortStopBits.STOP_BITS_ONE,
                eParity = CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortParity.PARITY_NONE
            };
            
            // 라이브러리 초기화
            var device = new CDeviceElectrostaticPGMS();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
        </member>
