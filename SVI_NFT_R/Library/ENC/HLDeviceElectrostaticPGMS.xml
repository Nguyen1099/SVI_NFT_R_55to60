        <member name="M:HLDeviceDLL.Electrostatic.PGMS.CDeviceElectrostaticPGMS.HLSaveNickName(System.Int32,System.String)">
            <summary>
            해당 어드레스에 닉네임을 설정하는 함수
            </summary>
            <param name="iAddress">어드레스</param>
            <param name="strNickName">닉네임</param>
            <returns>true = 성공, false = 실패</returns>
            <remarks>
            📌 매개변수 <paramref name="iAddress"/>의 입력 범위: 0 ~ 999<br/>
            📌 매개변수 <paramref name="strNickName"/>의 문자열 길이 범위: 0 ~ 27, ASCII
            📌 매개변수 <paramref name="strNickName"/>는 연결된 디바이스끼리 겹치지 않도록 유니크하게 정해야함
            </remarks>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new CDeviceElectrostaticPGMSDefine.CInitializeParameter()
            {
                eType = CDeviceCommunicationAbstract.CInitializeParameter.enumType.TYPE_SERIAL,
                strSerialPortName = "COM1",
                iSerialPortBaudrate = 19200,
                iSerialPortDataBits = 8,
                eStopBits = CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortStopBits.STOP_BITS_ONE,
                eParity = CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortParity.PARITY_NONE
            };
            
            // 라이브러리 초기화
            var device = new CDeviceElectrostaticPGMS();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 닉네임 설정
            int address = 0;
            string nickname = "EXAMPLE NICKNAME 01";
            if (device.HLSaveNickName(address, nickname) == false)
            {
                // 설정에 실패한 경우
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
        </member>
        <member name="M:HLDeviceDLL.Electrostatic.PGMS.CDeviceElectrostaticPGMS.HLLoadNickName(System.Int32,System.String@)">
            <summary>
            해당 어드레스에서 닉네임을 읽어오는 함수
            </summary>
            <param name="iAddress">어드레스</param>
            <param name="strNickName">닉네임 (실패시 공백)</param>
            <returns>true = 성공, false = 실패</returns>
            <remarks>
            📌 매개변수 <paramref name="iAddress"/>의 입력 범위: 0 ~ 999<br/>
            📌 매개변수 <paramref name="strNickName"/>의 문자열 길이 범위: 0 ~ 27, ASCII
            </remarks>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new CDeviceElectrostaticPGMSDefine.CInitializeParameter()
            {
                eType = CDeviceCommunicationAbstract.CInitializeParameter.enumType.TYPE_SERIAL,
                strSerialPortName = "COM1",
                iSerialPortBaudrate = 19200,
                iSerialPortDataBits = 8,
                eStopBits = CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortStopBits.STOP_BITS_ONE,
                eParity = CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortParity.PARITY_NONE
            };
            
            // 라이브러리 초기화
            var device = new CDeviceElectrostaticPGMS();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 닉네임 읽기
            int address = 0;
            string nickname;
            if (device.HLLoadNickName(address, out nickname) == true)
            {
                // 읽기에 성공한 경우
                Console.WriteLine($"읽은 값: {nickname}");
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
            <b>예제 코드 콘솔 출력</b>
            <code>
            읽은 값: EXAMPLE NICKNAME 01
            </code>
        </member>
        <member name="M:HLDeviceDLL.Electrostatic.PGMS.CDeviceElectrostaticPGMS.HLReadChannel(System.String,System.String[]@)">
            <summary>
            닉네임에 해당하는 디바이스의 전체 채널의 값을 읽어오는 함수
            </summary>
            <param name="strNickName">닉네임</param>
            <param name="strResult">각 채널의 저항 값 (혹은 상태 값을 나타내는 문자열)</param>
            <returns>true = 성공, false = 실패</returns>
            <remarks>
            📌 매개변수 <paramref name="strNickName"/>의 문자열 길이 범위: 0 ~ 27, ASCII<br/>
            📌 매개변수 <paramref name="strResult"/>에는 기본적으로 0 ~ 9999 사이의 값이 들어감. 값이 '123'일 경우 '1.23 Ω'을 의미함. 그리고 특정 값일 때 상태를 나타내는 문자열이 들어감.
            <list type="table">
                <listheader>
                    <term>값</term>
                    <description>의미</description>
                </listheader>
                <item>
                    <term><c>OPEN</c> (원래 값: 9999)</term>
                    <description>접지가 끊어진 상태</description>
                </item>
                <item>
                    <term><c>RANGE OVER</c> (원래 값: 9998)</term>
                    <description>9.99 Ω 초과시</description>
                </item>
                <item>
                    <term><c>DISABLE</c> (원래 값: 9997)</term>
                    <description>PORT 를 측정 안하게 GMS 기기에서 설정 해놓은 상태</description>
                </item>
            </list>
            </remarks>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new CDeviceElectrostaticPGMSDefine.CInitializeParameter()
            {
                eType = CDeviceCommunicationAbstract.CInitializeParameter.enumType.TYPE_SERIAL,
                strSerialPortName = "COM1",
                iSerialPortBaudrate = 19200,
                iSerialPortDataBits = 8,
                eStopBits = CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortStopBits.STOP_BITS_ONE,
                eParity = CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortParity.PARITY_NONE
            };
            
            // 라이브러리 초기화
            var device = new CDeviceElectrostaticPGMS();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 닉네임 읽기
            int address = 0;
            string nickname;
            if (device.HLLoadNickName(address, out nickname) == true)
            {
                // 모든 채널에 값 읽기
                string[] readValues;
                if (device.HLReadChannel(nickname, out readValues) == true)
                {
                    // 읽기에 성공한 경우
                    Console.WriteLine($"읽은 값: {{ {string.Join(", ", readValues)} }}");
                }
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
            <b>예제 코드 콘솔 출력</b>
            <code>
            읽은 값: { OPEN, 123, 432, RANGE OVER, DISABLE }
            </code>
        </member>
