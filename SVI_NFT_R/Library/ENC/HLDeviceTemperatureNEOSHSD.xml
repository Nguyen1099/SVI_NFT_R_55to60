        <member name="M:HLDeviceDLL.Temperature.NEOSHSD.CDeviceTemperatureNEOSHSD.HLIsConnected">
            <summary>
            통신 준비 상태를 반환하는 함수
            </summary>
            <returns>true: 통신이 준비된 상태<br/>false: 통신 준비가 안된 상태</returns>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new CDeviceTemperatureNEOSHSDDefine.CInitializeParameter()
            {
                eType = Common.CDeviceCommunicationAbstract.CInitializeParameter.enumType.TYPE_SERIAL,
                strSerialPortName = "COM21",
                iSerialPortBaudrate = 115200,
                iSerialPortDataBits = 8,
                eStopBits = Common.CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortStopBits.STOP_BITS_TWO,
                eParity = Common.CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortParity.PARITY_NONE
            };
            
            // 라이브러리 초기화
            var device = new CDeviceTemperatureNEOSHSD();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 통신 준비 상태 확인
            bool bIsConnected = device.HLIsConnected();
            Console.WriteLine($"통신 준비 상태: {bIsConnected}");
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
            <b>예제 코드 콘솔 출력</b>
            <code>
            통신 준비 상태: True
            </code>
        </member>
