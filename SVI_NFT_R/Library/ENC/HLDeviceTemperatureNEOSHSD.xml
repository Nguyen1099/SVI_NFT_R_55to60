        <member name="M:HLDeviceDLL.Temperature.NEOSHSD.CDeviceTemperatureNEOSHSD.HLReadTemp(System.Byte,System.Double@)">
            <summary>
            ID에 해당하는 디바이스의 온도 값을 읽는 함수
            </summary>
            <param name="byteID">ID</param>
            <param name="dTempData">온도 값(double형 데이터)</param>
            <returns>true = 성공, false = 실패</returns>
            <remarks>
            📌 매개변수 <paramref name="byteID"/>의 ID의 범위: 0 ~ 15 , Byte<br/>
            📌 매개변수 <paramref name="dTempData"/> 온도 : 2 Byte, Decimel 값 / 100.0
            </remarks>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new CDeviceTemperatureNEOSHSDDefine.CInitializeParameter()
            {
                eType = Common.CDeviceCommunicationAbstract.CInitializeParameter.enumType.TYPE_SERIAL,
                strSerialPortName = "COM21",
                iSerialPortBaudrate = 115200,
                iSerialPortDataBits = 8,
                eStopBits = Common.CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortStopBits.STOP_BITS_TWO,
                eParity = Common.CDeviceCommunicationAbstract.CInitializeParameter.enumSerialPortParity.PARITY_NONE
            };
            
            // 라이브러리 초기화
            var device = new CDeviceTemperatureNEOSHSD();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 닉네임 읽기
            // !!! NEOS-HSD 모델은 SlaveID가 0부터 시작한다
            // !!! NEOS-HSD200 모델은 SlaveID가 1부터 시작한다
            byte index = (byte)1;
            double readValue;
            
            if(device.HLReadTemp(index, out readValue) == false)
            {
                // 읽기 실패
                // 에러 코드
                // 0x01 온도 센서 에러           
                // 0x02 EEPROM 에러
                // 0x03 Checksum 에러
                // 0x04 LCD 에러
                // 0x05 485 에러
                return;
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
            <b>예제 코드 콘솔 출력</b>
            <code>
            읽은 값: ex) 272, 333
            </code>
        </member>
