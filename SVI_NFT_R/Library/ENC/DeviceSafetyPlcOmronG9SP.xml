            </summary>
            <remarks>
            📌 함수 호출시 <see cref="P:DeviceDLL.SafetyPlc.Omron.G9SP.DeviceSafetyPlcOmronG9SP.SendTagIoData"/> 값이 <c>Safety PLC</c>에 적용됨
            </remarks>
            <param name="safetyPlcMonitorDataOrNull"><see cref="T:DeviceDLL.SafetyPlc.Omron.G9SP.Define.ISafetyPlcMonitorData"/> 데이터 객체(실패시 <c>null</c> 반환)</param>
            <returns>true = 성공, false = 실패</returns>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new InitializeParameter()
            {
                RemoteHostName = "192.168.1.100",
                RemoteHostPort = 9600,
                NodeSafetyPlc = 100,
                NodeSelf = 2,
                ReceiveTimeout = TimeSpan.FromMilliseconds(200)
            };
            
            // 라이브러리 초기화
            var device = new DeviceSafetyPlcOmronG9SP();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 모니터 데이터 읽기
            ISafetyPlcMonitorData readValue;
            if (device.TryReadSafetyPlcMonitorData(out readValue) == true)
            {
                // 읽기에 성공한 경우
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
        </member>
