        <member name="M:DeviceDLL.SafetyPlc.Omron.G9SP.DeviceSafetyPlcOmronG9SP.TryReadSafetyPlcMonitorData(DeviceDLL.SafetyPlc.Omron.G9SP.Define.ISafetyPlcMonitorData@)">
            <summary>
