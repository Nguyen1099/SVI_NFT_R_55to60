            🚩 최초 초기화 이후에 초기화 파라미터 변경이 없다는 컨샙으로 구현되어 있음으로 값을 직접 변경해도 적용되지 않음으로 주의 할 것
            </remarks>
        </member>
        <member name="M:DeviceDLL.SafetyPlc.Omron.G9SP.DeviceSafetyPlcOmronG9SP.Initialize(DeviceDLL.SafetyPlc.Omron.G9SP.InitializeParameter)">
            <summary>
            라이브러리를 초기화하는 함수
            </summary>
            <remarks>
            <br>📌 입력된 초기화 파라미터로 라이브러리 내부에 코어를 초기화하고, 통신 자동 접속 스레드를 시작함</br>
            </remarks>
            <param name="initializeParameter">초기화 파라미터 객체</param>
            <returns>초기화 성공시 true를 실패시 false를 반환함</returns>
            <b>예제 코드</b>
            <code>
            // 초기화 파라미터 설정
            var initializeParameter = new InitializeParameter()
            {
                RemoteHostName = "192.168.1.100",
                RemoteHostPort = 9600,
                NodeSafetyPlc = 100,
                NodeSelf = 2,
                ReceiveTimeout = TimeSpan.FromMilliseconds(200)
            };
            
            // 라이브러리 초기화
            var device = new DeviceSafetyPlcOmronG9SP();
            if (device.Initialize(initializeParameter) == false)
            {
                // 초기화 실패
                return;
            }
            
            // 라이브러리 정리
            device.DeInitialize();
            return;
            </code>
        </member>
